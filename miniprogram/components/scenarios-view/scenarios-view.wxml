<!--components/scenarios-view/scenarios-view.wxml-->
<view class="scenarios-container">
  
  <!-- 1. 场景/课文列表页 -->
  <view class="list-wrapper" wx:if="{{!activeScenario}}">
    <!-- 顶层子板块切换 (情景对话 vs 常用短语) -->
    <view class="sub-tab-bar">
      <view class="sub-tab-item {{activeSubTab === 'scenarios' ? 'active' : ''}}" data-tab="scenarios" bindtap="onSwitchSubTab">
        情景课文
      </view>
      <view class="sub-tab-item {{activeSubTab === 'phrases' ? 'active' : ''}}" data-tab="phrases" bindtap="onSwitchSubTab">
        常用短语
      </view>
    </view>

    <!-- 场景对话面板 -->
    <block wx:if="{{activeSubTab === 'scenarios'}}">
      <!-- 大分类筛选器 -->
      <view class="category-tabs">
        <view class="category-tab {{selectedCategory === 'all' ? 'active' : ''}}" data-cat="all" bindtap="onSwitchCategory">
          全部
        </view>
        <view class="category-tab {{selectedCategory === '生活情景' ? 'active' : ''}}" data-cat="生活情景" bindtap="onSwitchCategory">
          日常情景
        </view>
        <view class="category-tab {{selectedCategory === '新闻演讲' ? 'active' : ''}}" data-cat="新闻演讲" bindtap="onSwitchCategory">
          新闻演讲
        </view>
      </view>

      <!-- 二级子分类筛选器 (仅在大分类不为 "all" 时展示) -->
      <view class="subcategory-bar" wx:if="{{selectedCategory !== 'all'}}">
        <view 
          class="sub-pill {{selectedSubCategory === 'all' ? 'active' : ''}}" 
          data-sub="all" 
          bindtap="onSwitchSubCategory"
        >
          全部
        </view>
        
        <block wx:if="{{selectedCategory === '生活情景'}}">
          <view class="sub-pill {{selectedSubCategory === '日常衣食' ? 'active' : ''}}" data-sub="日常衣食" bindtap="onSwitchSubCategory">日常衣食</view>
          <view class="sub-pill {{selectedSubCategory === '出行旅游' ? 'active' : ''}}" data-sub="出行旅游" bindtap="onSwitchSubCategory">出行旅游</view>
          <view class="sub-pill {{selectedSubCategory === '职场商务' ? 'active' : ''}}" data-sub="职场商务" bindtap="onSwitchSubCategory">职场商务</view>
          <view class="sub-pill {{selectedSubCategory === '生活求助' ? 'active' : ''}}" data-sub="生活求助" bindtap="onSwitchSubCategory">生活求助</view>
        </block>
        
        <block wx:if="{{selectedCategory === '新闻演讲'}}">
          <view class="sub-pill {{selectedSubCategory === '新闻资讯' ? 'active' : ''}}" data-sub="新闻资讯" bindtap="onSwitchSubCategory">新闻资讯</view>
          <view class="sub-pill {{selectedSubCategory === '主题演讲' ? 'active' : ''}}" data-sub="主题演讲" bindtap="onSwitchSubCategory">主题演讲</view>
        </block>
      </view>

      <!-- 状态与难度多维筛选栏 -->
      <view class="filter-panel">
        <!-- 学习状态筛选 -->
        <view class="filter-row">
          <text class="filter-label">学习进度</text>
          <view class="filter-pills">
            <view class="filter-pill {{selectedStatus === 'all' ? 'active' : ''}}" data-status="all" bindtap="onSwitchStatus">
              全部 ({{stats.total}})
            </view>
            <view class="filter-pill {{selectedStatus === 'unlearned' ? 'active' : ''}}" data-status="unlearned" bindtap="onSwitchStatus">
              未学习 ({{stats.unlearned}})
            </view>
            <view class="filter-pill {{selectedStatus === 'learned' ? 'active' : ''}}" data-status="learned" bindtap="onSwitchStatus">
              已学习 ({{stats.learned}})
            </view>
          </view>
        </view>

        <!-- 难度筛选 -->
        <view class="filter-row">
          <text class="filter-label">课文难度</text>
          <view class="filter-pills">
            <view class="filter-pill {{selectedDifficulty === 'all' ? 'active' : ''}}" data-difficulty="all" bindtap="onSwitchDifficulty">
              全部
            </view>
            <view class="filter-pill {{selectedDifficulty === '初级' ? 'active' : ''}}" data-difficulty="初级" bindtap="onSwitchDifficulty">
              初级
            </view>
            <view class="filter-pill {{selectedDifficulty === '中级' ? 'active' : ''}}" data-difficulty="中级" bindtap="onSwitchDifficulty">
              中级
            </view>
            <view class="filter-pill {{selectedDifficulty === '高级' ? 'active' : ''}}" data-difficulty="高级" bindtap="onSwitchDifficulty">
              高级
            </view>
          </view>
        </view>
      </view>

      <!-- 列表内容 -->
      <scroll-view class="list-scroll" scroll-y bindscrolltolower="onLoadMore">
        <view class="cards-grid">
          <view 
            class="scenario-card" 
            wx:for="{{filteredScenarios}}" 
            wx:key="id" 
            bindtap="onSelectScenario" 
            data-id="{{item.id}}"
          >
            <view class="card-header">
              <view class="header-left">
                <text class="category-badge {{item.category === '新闻演讲' ? 'classic' : 'daily'}}">{{item.category === '新闻演讲' ? '新闻演讲' : '日常情景'}}</text>
                <text class="difficulty-badge {{item.difficulty === '初级' ? 'easy' : (item.difficulty === '中级' ? 'medium' : 'hard')}}">{{item.difficulty}}</text>
              </view>
              <view class="learned-status" wx:if="{{item.isLearned}}">
                <icon class="learned-icon" type="success" size="12" color="#10B981" />
                <text class="learned-text">已学习</text>
              </view>
            </view>
            
            <view class="card-title">{{item.title}}</view>
            <view class="card-desc">{{item.description}}</view>
            
            <view class="card-footer">
              <text class="turns-count">共 {{item.dialogues.length}} 句对话/段落</text>
              <view class="start-btn">
                <text>进入学习</text>
                <text class="arrow">➔</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="empty-tip" wx:if="{{filteredScenarios.length === 0}}">
          暂无该分类的场景或演讲新闻
        </view>

        <!-- 分页加载状态提示 -->
        <view class="load-more-tip" wx:if="{{filteredScenarios.length > 0}}">
          <text>{{hasMore ? '下滑加载更多场景...' : '已加载全部场景 (共 ' + allFilteredScenarios.length + ' 个)'}}</text>
        </view>
        
        <view class="bottom-padding"></view>
      </scroll-view>
    </block>

    <!-- 常用短语面板 -->
    <block wx:if="{{activeSubTab === 'phrases'}}">
      <!-- 短语大类筛选器 -->
      <view class="phrase-category-bar">
        <view 
          class="phrase-sub-pill {{selectedPhraseCategory === 'all' ? 'active' : ''}}" 
          data-cat="all" 
          bindtap="onSwitchPhraseCategory"
        >
          全部
        </view>
        <view 
          class="phrase-sub-pill {{selectedPhraseCategory === category.id ? 'active' : ''}}" 
          wx:for="{{phraseCategories}}" 
          wx:key="id"
          wx:for-item="category"
          data-cat="{{category.id}}" 
          bindtap="onSwitchPhraseCategory"
        >
          {{category.name}}
        </view>
      </view>

      <scroll-view class="phrases-scroll" scroll-y bindscrolltolower="onLoadMorePhrases">
        <view class="phrases-grid">
          <block wx:for="{{phrasesData}}" wx:key="id" wx:for-item="category">
            <block wx:if="{{selectedPhraseCategory === 'all' || selectedPhraseCategory === category.id}}">
              <!-- 分类标头 -->
              <view class="phrase-section-header">
                <text class="section-title-text">{{category.name}}</text>
                <text class="section-count-text">({{category.items.length}} 个词/短语)</text>
              </view>
              
              <view class="phrase-cards-row">
                <view 
                  class="phrase-card" 
                  wx:for="{{category.items}}" 
                  wx:key="id" 
                  wx:for-item="phrase"
                  bindtap="onPlayPhrase"
                  data-thai="{{phrase.thai}}"
                >
                  <view class="phrase-card-main">
                    <text class="phrase-thai">{{phrase.thai}}</text>
                    <text class="phrase-phonetic">{{phrase.phonetic}}</text>
                    <text class="phrase-chinese">{{phrase.chinese}}</text>
                  </view>
                  <view class="phrase-play-icon">
                    <text class="speaker-icon">🔊</text>
                  </view>
                </view>
              </view>
            </block>
          </block>
        </view>
        <view class="bottom-padding"></view>
      </scroll-view>
    </block>
  </view>

  <!-- 2. 交互式剧场播放页 -->
  <view class="player-wrapper" wx:else>
    <!-- 顶部状态栏 -->
    <view class="player-header">
      <view class="back-action" bindtap="onBackToList">
        <text class="back-arrow">←</text>
        <text class="back-text">返回</text>
      </view>
      
      <view class="header-right">
        <!-- 语速选择 -->
        <view class="speed-selector">
          <view class="speed-option {{speechRate === 0.75 ? 'active' : ''}}" data-rate="0.75" bindtap="onChangeRate">0.75x</view>
          <view class="speed-option {{speechRate === 1.0 ? 'active' : ''}}" data-rate="1.0" bindtap="onChangeRate">1.0x</view>
          <view class="speed-option {{speechRate === 1.25 ? 'active' : ''}}" data-rate="1.25" bindtap="onChangeRate">1.25x</view>
          <view class="speed-option {{speechRate === 1.5 ? 'active' : ''}}" data-rate="1.5" bindtap="onChangeRate">1.5x</view>
        </view>
        
        <view class="auto-play-toggle">
          <text class="toggle-label">自动播放</text>
          <switch class="toggle-switch" checked="{{autoPlay}}" color="#4F46E5" bindchange="onToggleAutoPlay" />
        </view>
      </view>
    </view>

    <!-- 角色状态展示板 (Visual Novel 立绘效果) -->
    <view class="characters-stage">
      <view 
        class="stage-actor {{character.id === activeRoleId ? 'active-talking' : ''}} {{character.isNarrator ? 'hidden-actor' : ''}}"
        wx:for="{{stageCharacters}}"
        wx:for-item="character"
        wx:key="id"
      >
        <view class="actor-avatar-wrapper">
          <image class="actor-avatar" src="{{character.avatarUrl}}" mode="aspectFit" />
          <view class="talking-ripple" wx:if="{{character.id === activeRoleId && isPlayingAudio}}"></view>
        </view>
        <text class="actor-name">{{character.name}}</text>
        <text class="actor-role">{{character.role}}</text>
      </view>
    </view>

    <!-- 聊天气泡记录区 -->
    <scroll-view 
      class="chat-scroll" 
      scroll-y 
      scroll-into-view="{{lastViewId}}"
      scroll-with-animation
    >
      <view class="chat-flow">
        <block wx:for="{{activeScenario.dialogues}}" wx:key="id" wx:for-index="index">
          <view 
            id="bubble_{{item.id}}" 
            class="dialogue-line-container {{index <= currentTurnIndex ? 'visible-line' : 'hidden-line'}} {{item.roleId === 'P' || item.roleId === 'S' || activeScenario.characters[item.roleId].avatar === 'narrator' ? 'center-narrative' : (item.roleId === leftRoleId ? 'left-speech' : 'right-speech')}}"
          >
            <!-- 旁白/演讲叙事块 -->
            <block wx:if="{{item.roleId === 'P' || item.roleId === 'S' || activeScenario.characters[item.roleId].avatar === 'narrator'}}">
              <view 
                class="narrative-box {{index === currentTurnIndex ? 'active-highlight' : ''}}"
                bindtap="onTapTurn" 
                data-index="{{index}}"
              >
                <!-- 泰语分词发音拼读行 -->
                <view class="narrative-thai">
                  <view class="segmented-sentence-wrap centered">
                    <view 
                      class="word-unit {{w.isUnknown ? 'unknown-word-unit' : ''}}" 
                      wx:for="{{item.segmentedWords}}" 
                      wx:for-item="w" 
                      wx:key="index"
                      catchtap="onPlayWordDirect"
                      data-word="{{w.word}}"
                      data-meaning="{{w.meaning}}"
                    >
                      <text class="word-meaning-top">{{w.shortMeaning || ' '}}</text>
                      <text class="word-phonetic-above">{{w.phonetic || ' '}}</text>
                      <text class="word-text-below">{{w.word}}</text>
                    </view>
                  </view>
                  <image class="play-mini-icon" src="/assets/icons/volume-small.svg" />
                </view>
                <view class="narrative-chinese">{{item.chinese}}</view>
              </view>
            </block>
            
            <!-- 左右聊天气泡 -->
            <block wx:else>
              <!-- 头像 -->
              <image 
                class="bubble-avatar" 
                src="{{activeScenario.characters[item.roleId].avatarUrl}}" 
                mode="aspectFit"
              />
              
              <!-- 气泡 -->
              <view class="speech-bubble-group">
                <view class="speaker-title">{{activeScenario.characters[item.roleId].name}}</view>
                <view 
                  class="speech-bubble {{index === currentTurnIndex ? 'active-highlight' : ''}} {{index === currentTurnIndex && isPlayingAudio ? 'talking-glow' : ''}}"
                  bindtap="onTapTurn" 
                  data-index="{{index}}"
                >
                  <!-- 泰语分词发音拼读行 -->
                  <view class="speech-thai">
                    <view class="segmented-sentence-wrap">
                      <view 
                        class="word-unit {{w.isUnknown ? 'unknown-word-unit' : ''}}" 
                        wx:for="{{item.segmentedWords}}" 
                        wx:for-item="w" 
                        wx:key="index"
                        catchtap="onPlayWordDirect"
                        data-word="{{w.word}}"
                        data-meaning="{{w.meaning}}"
                      >
                        <text class="word-meaning-top">{{w.shortMeaning || ' '}}</text>
                        <text class="word-phonetic-above">{{w.phonetic || ' '}}</text>
                        <text class="word-text-below">{{w.word}}</text>
                      </view>
                    </view>
                    <image class="play-mini-icon" src="/assets/icons/volume-small.svg" />
                  </view>
                  <view class="speech-chinese">{{item.chinese}}</view>
                </view>
              </view>
            </block>
          </view>
        </block>
      </view>
      <view class="bottom-padding-chat"></view>
    </scroll-view>

    <!-- 底部控制面板 -->
    <view class="player-controls">
      <!-- 进度指示器 -->
      <view class="progress-bar-container">
        <view class="progress-info">
          <text class="progress-title">{{activeScenario.title}}</text>
          <text class="progress-steps">{{currentTurnIndex + 1}} / {{activeScenario.dialogues.length}}</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{((currentTurnIndex + 1) / activeScenario.dialogues.length) * 100}}%"></view>
        </view>
      </view>
      
      <!-- 按钮面板 -->
      <view class="control-buttons">
        <button 
          class="ctrl-btn secondary {{currentTurnIndex === 0 ? 'disabled' : ''}}" 
          bindtap="onPrevTurn" 
          disabled="{{currentTurnIndex === 0}}"
        >
          上一句
        </button>
        
        <button class="ctrl-btn play-again" bindtap="onReplayTurn">
          <image class="btn-icon" src="/assets/icons/volume.svg" />
          <text>发音</text>
        </button>
        
        <button 
          class="ctrl-btn primary" 
          bindtap="onNextTurn"
        >
          {{currentTurnIndex === activeScenario.dialogues.length - 1 ? '学完退出' : '下一句'}}
        </button>
      </view>
      
      <!-- 二级工具面板 (加入笔记本) -->
      <view class="utility-actions">
        <view class="util-action-btn star-trigger" bindtap="onToggleStarSentence">
          <text class="util-star-icon {{isSentenceStarred ? 'starred' : ''}}">★</text>
          <text>{{isSentenceStarred ? '已存笔记' : '存笔记本'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 3. 词汇拆解滑出式半屏面板 (Bottom Sheet) -->
  <view class="bottom-sheet-mask {{showBreakdown ? 'show' : ''}}" bindtap="onCloseBreakdown"></view>
  <view class="bottom-sheet-content {{showBreakdown ? 'show' : ''}}">
    <view class="sheet-header">
      <view class="sheet-indicator"></view>
      <view class="sheet-title-row">
        <text class="sheet-title">泰语整句分词拆解</text>
        <view class="sheet-close" bindtap="onCloseBreakdown">✕</view>
      </view>
      <!-- 当前句子预览 -->
      <view class="sheet-sentence-preview" bindtap="onReplayTurn">
        <text class="preview-thai">{{activeTurnText}}</text>
        <image class="preview-play" src="/assets/icons/volume.svg" />
      </view>
    </view>
    
    <scroll-view class="sheet-scroll" scroll-y>
      <view class="words-list">
        <view 
          class="word-card-item {{word.isUnknown ? 'unknown-card' : ''}}" 
          wx:for="{{segmentedWords}}" 
          wx:key="index"
          bindtap="onPlayWord"
          data-word="{{word.word}}"
        >
          <view class="word-card-top">
            <text class="word-spelling">{{word.word}}</text>
            <image class="word-play-icon" src="/assets/icons/volume-small.svg" />
          </view>
          
          <view class="word-phonetic" wx:if="{{word.phonetic}}">[{{word.phonetic}}]</view>
          <view class="word-phonetic placeholder" wx:else>[无音标]</view>
          
          <view class="word-meaning">{{word.meaning}}</view>
          
          <view class="word-actions" catchtap="noBubble">
            <view class="word-action-tag {{word.starred ? 'starred' : ''}}" catchtap="onToggleStarWord" data-item="{{word}}">
              {{word.starred ? '★ 已收藏' : '☆ 存生词'}}
            </view>
          </view>
        </view>
      </view>
      
      <view class="sheet-tip">💡 点击词卡可单独发音；点击“存生词”可将单词存入笔记本以供闪卡复习。</view>
      <view class="bottom-padding-sheet"></view>
    </scroll-view>
  </view>
  
</view>
